PORT=4242
APP_URL=http://localhost:4242

# Pesapal credentials. Never commit real secrets.
PESAPAL_ENV=sandbox
PESAPAL_CONSUMER_KEY=your_consumer_key_here
PESAPAL_CONSUMER_SECRET=your_consumer_secret_here

# Required for real Pesapal checkout.
# Register a public IPN URL, then paste the returned IPN ID here.
# Localhost cannot receive Pesapal IPN notifications.
PESAPAL_IPN_ID=your_registered_ipn_id_here

PREMIUM_PRICE_AMOUNT=250
PREMIUM_PRICE_CURRENCY=KES
